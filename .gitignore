-- ====================================================================
-- AWESOME HUB: PART 2 (AUTOMATION ENGINE LOGIC)
-- ====================================================================
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
if not player then return end

-- References the shared UI instance pointers from Part 1 execution
local sharedData = _G.AwesomeHubShared or {}
local mainGui = sharedData.MainGui
local autoFarmBtn = sharedData.AutoFarmBtn
local hpButton = sharedData.HpButton

if not mainGui or not autoFarmBtn or not hpButton then
    warn("[AwesomeHub] Part 2 Failure: Ensure Part 1 UI Script is running first!")
    return
end

-- ====== ENVIRONMENT PATH SELECTION METRICS ====== 
local CURRENT_SETTINGS = nil

if Workspace:FindFirstChild("Items") then
    CURRENT_SETTINGS = {
        ItemsFolder = Workspace:WaitForChild("Items"),
        DropZone = Vector3.new(271, 2559, -28),
        TargetItems = {
            ["Lionel Cactuseli"] = true, ["Chillin Chili"] = true,
            ["Tirilikalika Tirilikalako"] = true, ["Tric Trac Barabum"] = true,
        }
    }
    print("[AwesomeHub] Game 1 detected. Syncing item trees...")
elseif Workspace:FindFirstChild("SpawnedBrainrots") then
    CURRENT_SETTINGS = {
        ItemsFolder = Workspace:WaitForChild("SpawnedBrainrots"),
        DropZone = Vector3.new(-64, 6, -193),
        TargetItems = {
            ["Trollface"] = true, ["Pepe"] = true, ["Quesadilla Crocodila"] = true,
        }
    }
    print("[AwesomeHub] Game 2 detected. Syncing item trees...")
else
    CURRENT_SETTINGS = {
        ItemsFolder = Workspace:WaitForChild("SpawnedBrainrots"),
        DropZone = Vector3.new(-64, 6, -193),
        TargetItems = {
            ["Trollface"] = true, ["Pepe"] = true, ["Quesadilla Crocodila"] = true,
        }
    }
    print("[AwesomeHub] Fallback state active. Targeting Game 2 assets...")
end

local INTERACT_DELAY = 0.8 
local isFarming = false
local isHpFarming = false
local flySpeed = 120 -- Underground flight movement tracking speed context

-- ====== NOCLIP LINEAR SLIDE BYPASS ROUTINE ====== 
local function smoothUndergroundFly(targetPosition)
    local char = player.Character if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end
    
    -- Drop 35 studs below the map terrain layer mesh
    local deepStart = hrp.Position - Vector3.new(0, 35, 0)
    local deepTarget = targetPosition - Vector3.new(0, 35, 0)
    
    hrp.CFrame = CFrame.new(deepStart)
    task.wait(0.05)
    
    local distance = (deepStart - deepTarget).Magnitude
    local duration = distance / flySpeed
    
    -- Kill collision metrics temporarily to ensure smooth slide tracking
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = false end
    end
    
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(deepTarget)})
    tween:Play()
    tween.Completed:Wait()
    
    -- Ascend directly into prompt interaction coordinates
    hrp.CFrame = CFrame.new(targetPosition + Vector3.new(0, 3, 0))
    task.wait(0.1)
end

local function teleportTo(position) 
    local char = player.Character if not char then return end 
    local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end 
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if hum then hum.Sit = true end
    task.wait(0.01)
    hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0)) 
    hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
    hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
    task.wait(0.3) 
    if hum then hum.Sit = false end 
end

local function firePrompt(prompt) 
    if not prompt then return end 
    if fireproximityprompt then 
        pcall(function() fireproximityprompt(prompt) end)
    else 
        pcall(function() 
            prompt:InputHoldBegin() 
            task.wait((prompt.HoldDuration or 0) + INTERACT_DELAY) 
            prompt:InputHoldEnd() 
        end) 
    end 
end

-- BUTTON 1 ENGINE: Standard Safe Jump Loops
local function startFarmingLoop() 
    while isFarming do 
        local foundItems = false 
        local folder = CURRENT_SETTINGS.ItemsFolder
        
        if folder and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
            for _, object in ipairs(folder:GetDescendants()) do 
                if not isFarming then break end 
                if CURRENT_SETTINGS.TargetItems[object.Name] then 
                    local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true) 
                    local part = object:IsA("BasePart") and object or object:FindFirstChildWhichIsA("BasePart", true)
                    
                    if part and prompt then 
                        foundItems = true 
                        teleportTo(part.Position) 
                        task.wait(0.3) 
                        firePrompt(prompt) 
                        task.wait(0.3) 
                        if isFarming then 
                            teleportTo(CURRENT_SETTINGS.DropZone) 
                            task.wait(0.5) 
                        end 
                    end 
                end 
            end 
        end 
        task.wait(foundItems and 2.5 or 4.0) 
    end 
end

-- BUTTON 2 ENGINE: Underground Flight Sweep Loops
local function startHpLoop()
    while isHpFarming do
        local foundItems = false
        local folder = CURRENT_SETTINGS.ItemsFolder
        
        if folder and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            for _, object in ipairs(folder:GetDescendants()) do
                if not isHpFarming then break end
                if CURRENT_SETTINGS.TargetItems[object.Name] then
                    local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true)
                    local part = object:IsA("BasePart") and object or object:FindFirstChildWhichIsA("BasePart", true)
                    
                    if part and prompt then
                        foundItems = true
                        smoothUndergroundFly(part.Position)
                        task.wait(0.3)
                        firePrompt(prompt)
                        task.wait(0.3)
                        if isHpFarming then
                            smoothUndergroundFly(CURRENT_SETTINGS.DropZone)
                            task.wait(0.5)
                        end
                    end
                end
            end
        end
        task.wait(foundItems and 2.0 or 4.0)
    end
end

-- ====== INTERFACE CLICK CONNECTION TRIGGERS ====== 

autoFarmBtn.MouseButton1Click:Connect(function() 
    isFarming = not isFarming 
    if isFarming and isHpFarming then isHpFarming = false hpButton.Text = "+1 hp for brainrots" hpButton.BackgroundColor3 = Color3.fromRGB(53,53,53) end 
    autoFarmBtn.BackgroundColor3 = isFarming and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(53, 53, 53)
    autoFarmBtn.Text = isFarming and "Auto Farm: ON" or "Auto Farm"
    if isFarming then task.spawn(startFarmingLoop) end
end)

hpButton.MouseButton1Click:Connect(function()
    isHpFarming = not isHpFarming
    if isHpFarming and isFarming then isFarming = false autoFarmBtn.Text = "Auto Farm" autoFarmBtn.BackgroundColor3 = Color3.fromRGB(53,53,53) end 
    hpButton.BackgroundColor3 = isHpFarming and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(53, 53, 53)
    hpButton.Text = isHpFarming and "+1 HP: ON" or "+1 hp for brainrots"
    if isHpFarming then task.spawn(startHpLoop) end
end)

-- Keyboard Framework Hook bind: Global Keybind Toggle (Using 'P' Key)
UserInputService.InputBegan:Connect(function(input, processed) 
    if not processed and input.KeyCode == Enum.KeyCode.P then 
        mainGui.Visible = not mainGui.Visible 
    end 
end)

print("[AwesomeHub] Part 2: Automation engine systems ready. Press 'P' to minimize.")
