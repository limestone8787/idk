local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer 
if not player then return end

-- Executor-safe parent canvas container initialization
local parentGui = (gethui and gethui()) or CoreGui or player:WaitForChild("PlayerGui")

-- ====== AUTO FARM SETTINGS ====== 
local TELEPORT_DROP_ZONE = Vector3.new(271, 2559, -28) 
local INTERACT_DELAY = 0.6 -- Holds the prompt longer to guarantee collection under server lag

local targetItems = { 
    ["Lionel Cactuseli"] = true, 
    ["Chillin Chili"] = true, 
    ["Tirilikalika Tirilikalako"] = true, 
    ["Tric Trac Barabum"] = true,
    ["Cerberus"] = true
}

local isFarming = false

-- ====== GUI CONSTRUCTION ====== 
