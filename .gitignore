local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer 
if not player then return end

-- Use CoreGui for executor stability
local parentGui = (gethui and gethui()) or CoreGui or player:WaitForChild("PlayerGui")

-- ====== AUTO FARM SETTINGS ====== 
-- Updated to look inside Workspace -> "items" folder
local ITEMS_PARENT = Workspace:WaitForChild("items") 
local TELEPORT_DROP_ZONE = Vector3.new(271, 2559, -28) 
local INTERACT_DELAY = 0.3

local targetItems = { 
	["Lionel Cactuseli"] = true, 
	["Chillin Chili"] = true, 
	["Tirilikalika Tirilikalako"] = true, 
	["Tric Trac Barabum"] = true, 
}

local isFarming = false

-- ====== GUI CONSTRUCTION (TEXT SIZE 10) ====== 
local screenGui = Instance.new("ScreenGui") 
screenGui.Name = "AWESOME_HUB" 
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.ResetOnSpawn = false
screenGui.Parent = parentGui

local mainGui = Instance.new("Frame") 
mainGui.Name = "MainGui" 
mainGui.BackgroundColor3 = Color3.fromRGB(50, 50, 50) 
mainGui.Size = UDim2.new(0, 640, 0, 381) 
mainGui.Position = UDim2.new(0.307, -22, 0.25977, 13) 
mainGui.BorderSizePixel = 0
mainGui.Parent = screenGui

Instance.new("UICorner", mainGui)
local strokeMain = Instance.new("UIStroke", mainGui)
strokeMain.Thickness = 5 
strokeMain.Color = Color3.fromRGB(32, 32, 32)

local drag = Instance.new("UIDragDetector", mainGui)
drag.DragUDim2 = UDim2.new(0, -15, 0, -3)

local titleLabel = Instance.new("TextLabel", mainGui) 
titleLabel.BackgroundTransparency = 1 
titleLabel.Text = "Awesome Hub" 
titleLabel.TextSize = 10 
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255) 
titleLabel.Font = Enum.Font.SourceSansBold 
titleLabel.Size = UDim2.new(0, 200, 0, 50) 
titleLabel.Position = UDim2.new(0.34375, 0, 0, 0)

local drillToggleBtn = Instance.new("TextButton", mainGui) 
drillToggleBtn.Text = "Drill For Brainrots" 
drillToggleBtn.TextSize = 10 
drillToggleBtn.Size = UDim2.new(0, 142, 0, 42) 
drillToggleBtn.Position = UDim2.new(0.02969, 0, 0.04199, 0) 
drillToggleBtn.BackgroundColor3 = Color3.fromRGB(53, 53, 53) 
drillToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255) 
drillToggleBtn.BorderSizePixel = 0 

Instance.new("UICorner", drillToggleBtn).CornerRadius = UDim.new(0, 6)
local strokeBtn1 = Instance.new("UIStroke", drillToggleBtn)
strokeBtn1.Thickness = 3 
strokeBtn1.Color = Color3.fromRGB(31, 31, 31)

local drillSubPanel = Instance.new("Frame", mainGui) 
drillSubPanel.BackgroundColor3 = Color3.fromRGB(45, 45, 45) 
drillSubPanel.Size = UDim2.new(0, 430, 0, 302) 
drillSubPanel.Position = UDim2.new(0.3, 0, 0.15, 0) 
drillSubPanel.Visible = false 

Instance.new("UICorner", drillSubPanel)
local strokeSub = Instance.new("UIStroke", drillSubPanel)
strokeSub.Thickness = 5 
strokeSub.Color = Color3.fromRGB(32, 32, 32)

local autoFarmBtn = Instance.new("TextButton", drillSubPanel) 
autoFarmBtn.Text = "Auto Farm" 
autoFarmBtn.TextSize = 10 
autoFarmBtn.Size = UDim2.new(0, 142, 0, 42) 
autoFarmBtn.Position = UDim2.new(0.334, 0, 0.058, 0) 
autoFarmBtn.BackgroundColor3 = Color3.fromRGB(53, 53, 53) 
autoFarmBtn.TextColor3 = Color3.fromRGB(255, 255, 255) 
autoFarmBtn.BorderSizePixel = 0 

Instance.new("UICorner", autoFarmBtn).CornerRadius = UDim.new(0, 6)
local strokeAuto = Instance.new("UIStroke", autoFarmBtn)
strokeAuto.Thickness = 3 
strokeAuto.Color = Color3.fromRGB(31, 31, 31)

-- ====== LOGIC ====== 
local function teleportTo(position) 
	local char = player.Character if not char then return end 
	local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end 
	hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0)) 
end

local function firePrompt(prompt) 
	if not prompt then return end 
	if fireproximityprompt then 
		fireproximityprompt(prompt) 
	else 
		pcall(function() 
			prompt:InputHoldBegin() 
			task.wait((prompt.HoldDuration or 0) + INTERACT_DELAY) 
			prompt:InputHoldEnd() 
		end) 
	end 
end

local function startFarmingLoop() 
	while isFarming do 
		local foundItems = false 
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
			for _, object in ipairs(ITEMS_PARENT:GetChildren()) do 
				if not isFarming then break end 
				if targetItems[object.Name] then 
					local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true) 
					local part = object:IsA("BasePart") and object or object:FindFirstChildWhichIsA("BasePart", true)
					
					if part and prompt then 
						foundItems = true 
						teleportTo(part.Position) 
						task.wait(0.1) 
						firePrompt(prompt) 
						task.wait(0.1) 
						teleportTo(TELEPORT_DROP_ZONE) 
						task.wait(0.2) 
					end 
				end 
			end 
		end 
		task.wait(foundItems and 0.3 or 1.5) 
	end 
end

-- ====== INTERACTION ====== 
drillToggleBtn.MouseButton1Click:Connect(function() 
	drillSubPanel.Visible = not drillSubPanel.Visible 
end)

autoFarmBtn.MouseButton1Click:Connect(function() 
	isFarming = not isFarming 
	autoFarmBtn.BackgroundColor3 = isFarming and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(53, 53, 53)
	autoFarmBtn.Text = isFarming and "Auto Farm: ON" or "Auto Farm"
	if isFarming then task.spawn(startFarmingLoop) end
end)

UserInputService.InputBegan:Connect(function(input, processed) 
	if not processed and input.KeyCode == Enum.KeyCode.K then mainGui.Visible = not mainGui.Visible end 
end)
