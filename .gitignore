-- ====== VOLLSTÄNDIGE CHICKEN-GAME AUTOMATION ====== 
local function startEggFarmingLoop()
    local remoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    while _G.isEggFarming do
        local character = player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        
        -- Eier einsammeln via Touch-Interests
        if hrp and _G.eggsFolder then
            for _, egg in ipairs(_G.eggsFolder:GetChildren()) do
                if not _G.isEggFarming then break end
                local targetPart = egg:FindFirstChild("Part")
            
                if targetPart then
                    if firetouchinterest then
                        firetouchinterest(hrp, targetPart, 0)
                        task.wait(0.05)
                        firetouchinterest(hrp, targetPart, 1)
                        task.wait(0.05)
                    end
                end
            end
        end
        
        -- Alle ungeschnittenen Remote-Funktionen nacheinander triggern
        if _G.isEggFarming then
            pcall(function()
                remoteFunction:InvokeServer("Deposit Eggs")
                remoteFunction:InvokeServer("Collect Cash")
                remoteFunction:InvokeServer("Buy Chickens", 5)
                remoteFunction:InvokeServer("Merge Chickens")
                remoteFunction:InvokeServer("Upgrade Process Level")
            end)
        end
        
        -- Verhindert Client-Abstürze bei Server-Lag
        task.wait(1)
    end
end

-- Menüführung aktivieren
_G.chickenToggleBtn.MouseButton1Click:Connect(function() 
    _G.chickenSubPanel.Visible = not _G.chickenSubPanel.Visible 
end)

-- Schleife mit dem UI-Button verbinden
eggFarmBtn.MouseButton1Click:Connect(function()
    _G.isEggFarming = not _G.isEggFarming
    eggFarmBtn.BackgroundColor3 = _G.isEggFarming and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(53, 53, 53)
    eggFarmBtn.Text = _G.isEggFarming and "Egg Farm: ON" or "Egg Farm"
    if _G.isEggFarming then task.spawn(startEggFarmingLoop) end
end)
