-- ────────────────────────────────────────────────
-- HELPERS
-- ────────────────────────────────────────────────
local function showStatus(msg, color)
    statusLabel.Text = msg
    statusLabel.TextColor3 = color or Color3.fromRGB(120, 220, 120)
    task.delay(3, function()
        if statusLabel.Text == msg then statusLabel.Text = "" end
    end)
end

local function getCategory(name)
    return ITEM_CATEGORIES[name] or "Other"
end

local function getCategoryColor(catName)
    for _, info in ipairs(CATEGORY_INFO) do
        if info.name == catName then return info.color end
    end
    return Color3.fromRGB(160, 160, 180)
end

-- ────────────────────────────────────────────────
-- TELEPORT
-- ────────────────────────────────────────────────
local function getPlayerCFrame()
    character = player.Character
    if not character then return nil end
    local root = character:FindFirstChild("HumanoidRootPart")
    return root and root.CFrame or nil
end

local function moveItem(item, targetCFrame)
    if item:IsA("Model") then
        if item.PrimaryPart then
            item:SetPrimaryPartCFrame(targetCFrame)
        else
            local first
            for _, d in ipairs(item:GetDescendants()) do
                if d:IsA("BasePart") then
                    if not first then first = d end
                end
            end
            if first then
                local delta = targetCFrame.Position - first.Position
                for _, d in ipairs(item:GetDescendants()) do
                    if d:IsA("BasePart") then d.CFrame = d.CFrame + delta end
                end
            end
        end
        return true
    elseif item:IsA("BasePart") then
        item.CFrame = targetCFrame
        return true
    end
    return false
end

local function teleportAllByName(name)
    local cf = getPlayerCFrame()
    if not cf then showStatus("❌ No character!", Color3.fromRGB(255,100,100)); return end
    local matches = {}
    for _, item in ipairs(ITEMS_FOLDER:GetChildren()) do
        if item.Name == name then table.insert(matches, item) end
    end
    if #matches == 0 then showStatus("⚠️ None found: " .. name, Color3.fromRGB(255,200,80)); return end
    local GAP = 3
    local startX = -((#matches - 1) * GAP / 2)
    for i, item in ipairs(matches) do
        moveItem(item, cf * CFrame.new(OFFSET + Vector3.new(startX + (i-1)*GAP, 0, 0)))
    end
    showStatus("✅ Teleported " .. #matches .. "x " .. name)
end

-- ────────────────────────────────────────────────
-- STATE
-- ────────────────────────────────────────────────
local selectedCategory = "All"
local categoryButtons = {}
local allItemRows = {}

-- ────────────────────────────────────────────────
-- BUILD LIST  (one row per UNIQUE name)
-- ────────────────────────────────────────────────
local function buildList(filter)
    for _, r in ipairs(allItemRows) do r:Destroy() end
    allItemRows = {}
    filter = (filter or ""):lower()

    -- Count & collect unique names
    local nameCounts = {}
    local nameOrder  = {}
    for _, item in ipairs(ITEMS_FOLDER:GetChildren()) do
        if not nameCounts[item.Name] then
            table.insert(nameOrder, item.Name)
            nameCounts[item.Name] = 0
        end
        nameCounts[item.Name] += 1
    end

    -- Sort alphabetically
    table.sort(nameOrder)

    for _, name in ipairs(nameOrder) do
        local cat = getCategory(name)
        local matchesCat    = selectedCategory == "All" or cat == selectedCategory
        local matchesSearch = filter == "" or name:lower():find(filter, 1, true)
        if not (matchesCat and matchesSearch) then continue end

        local count    = nameCounts[name]
        local catColor = getCategoryColor(cat)

        local row = Instance.new("Frame", scrollFrame)
        row.Size = UDim2.new(1, 0, 0, 36)
        row.BackgroundTransparency = 1
        row.BorderSizePixel = 0

        local rl = Instance.new("UIListLayout", row)
        rl.FillDirection = Enum.FillDirection.Horizontal
        rl.SortOrder = Enum.SortOrder.LayoutOrder
        rl.Padding = UDim.new(0, 4)

        -- Coloured category stripe
        local stripe = Instance.new("Frame", row)
        stripe.Size = UDim2.new(0, 6, 1, 0)
        stripe.BackgroundColor3 = catColor
        stripe.BorderSizePixel = 0
        stripe.LayoutOrder = 0
        Instance.new("UICorner", stripe).CornerRadius = UDim.new(0, 3)

        -- Main button: shows name + count if >1
        local label = count > 1 and (name .. "  ×" .. count) or name
        local mainBtn = Instance.new("TextButton", row)
        mainBtn.Size = UDim2.new(count > 1 and 0.68 or 1, -10, 1, 0)
        mainBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 65)
        mainBtn.BorderSizePixel = 0
        mainBtn.Text = "  " .. label
        mainBtn.TextColor3 = Color3.fromRGB(210, 210, 255)
        mainBtn.TextSize = 13
        mainBtn.Font = Enum.Font.Gotham
        mainBtn.TextXAlignment = Enum.TextXAlignment.Left
        mainBtn.LayoutOrder = 1
        Instance.new("UICorner", mainBtn).CornerRadius = UDim.new(0, 6)
        mainBtn.MouseEnter:Connect(function() mainBtn.BackgroundColor3 = Color3.fromRGB(60,80,120) end)
        mainBtn.MouseLeave:Connect(function() mainBtn.BackgroundColor3 = Color3.fromRGB(40,40,65) end)
        -- TP one (the first found)
        mainBtn.Activated:Connect(function()
            local cf = getPlayerCFrame()
            if not cf then showStatus("❌ No character!", Color3.fromRGB(255,100,100)); return end
            local found = ITEMS_FOLDER:FindFirstChild(name)
            if found then
                moveItem(found, cf * CFrame.new(OFFSET))
                showStatus("✅ Teleported: " .. name)
            end
        end)

        -- TP All button (only when count > 1)
        if count > 1 then
            local allBtn = Instance.new("TextButton", row)
            allBtn.Size = UDim2.new(0.32, -4, 1, 0)
            allBtn.BackgroundColor3 = Color3.fromRGB(50, 90, 60)
            allBtn.BorderSizePixel = 0
            allBtn.Text = "TP All"
            allBtn.TextColor3 = Color3.fromRGB(140, 255, 160)
            allBtn.TextSize = 12
            allBtn.Font = Enum.Font.GothamBold
            allBtn.LayoutOrder = 2
            Instance.new("UICorner", allBtn).CornerRadius = UDim.new(0, 6)
            allBtn.MouseEnter:Connect(function() allBtn.BackgroundColor3 = Color3.fromRGB(60,130,80) end)
            allBtn.MouseLeave:Connect(function() allBtn.BackgroundColor3 = Color3.fromRGB(50,90,60) end)
            allBtn.Activated:Connect(function() teleportAllByName(name) end)
        end

        table.insert(allItemRows, row)
    end
end

-- ────────────────────────────────────────────────
-- BUILD CATEGORY TABS
-- ────────────────────────────────────────────────
local function updateCategoryHighlight()
    for catName, btn in pairs(categoryButtons) do
        local sel = catName == selectedCategory
        local col = getCategoryColor(catName)
        btn.BackgroundColor3 = sel and col or Color3.fromRGB(30,30,50)
        btn.TextColor3 = sel and Color3.fromRGB(20,20,30) or col
    end
end

local function buildCategoryTabs()
    for _, btn in pairs(categoryButtons) do btn:Destroy() end
    categoryButtons = {}

    -- Which categories actually exist in the folder?
    local present = { ["All"] = true }
    for _, item in ipairs(ITEMS_FOLDER:GetChildren()) do
        present[getCategory(item.Name)] = true
    end

    local order = 0
    for _, info in ipairs(CATEGORY_INFO) do
        if not present[info.name] then continue end
        local btn = Instance.new("TextButton", catScroll)
        btn.Size = UDim2.new(0, 0, 1, 0)
        btn.AutomaticSize = Enum.AutomaticSize.X
        btn.BackgroundColor3 = Color3.fromRGB(30,30,50)
        btn.Text = " " .. info.name .. " "
        btn.TextColor3 = info.color
        btn.TextSize = 11
        btn.Font = Enum.Font.GothamBold
        btn.BorderSizePixel = 0
        btn.LayoutOrder = order
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        local p = Instance.new("UIPadding", btn)
        p.PaddingLeft = UDim.new(0,6); p.PaddingRight = UDim.new(0,6)

        btn.Activated:Connect(function()
            selectedCategory = info.name
            updateCategoryHighlight()
            buildList(searchBox.Text)
        end)

        categoryButtons[info.name] = btn
        order += 1
    end
    updateCategoryHighlight()
end

-- ────────────────────────────────────────────────
-- INIT & TOGGLE
-- ────────────────────────────────────────────────
buildCategoryTabs()
buildList()

searchBox:GetPropertyChangedSignal("Text"):Connect(function() buildList(searchBox.Text) end)
closeBtn.Activated:Connect(function() frame.Visible = false end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == GUI_KEY then
        frame.Visible = not frame.Visible
        if frame.Visible then
            buildCategoryTabs()
            buildList(searchBox.Text)
        end
    end
end)
local function patchPrompts(parent)
    for _, obj in ipairs(parent:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == "Open Chest" then
            obj.HoldDuration = 0
        end
    end
end
 
-- Patch all existing chests
patchPrompts(workspace)
 
-- Also patch any chests that load in later
workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") and obj.ActionText == "Open Chest" then
        obj.HoldDuration = 0
    end
end)
