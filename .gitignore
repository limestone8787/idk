-- ====== SYSTEM ENGINE LOGIC ====== 
local function dbg(...) 
	local t = {...} 
	for i = 1, #t do t[i] = tostring(t[i]) end 
	print("[AutoFarm]", table.concat(t, " ")) 
end

local function teleportTo(position) 
	local char = player.Character if not char then return end 
	local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end 
	
	-- Position offset safety buffer
	hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0)) 
	task.wait(0.12) 
end

local function getItemPosition(item) 
	if not item then return nil end 
	if item:IsA("BasePart") then 
		return item.Position 
	elseif item:IsA("Model") then 
		if item.PrimaryPart then return item.PrimaryPart.Position end 
		local part = item:FindFirstChildWhichIsA("BasePart", true) 
		if part then return part.Position end 
	else 
		local descendantPart = item:FindFirstChildWhichIsA("BasePart", true) 
		if descendantPart then return descendantPart.Position end 
	end 
	return nil 
end

local function firePrompt(prompt) 
	if not prompt then return false end 
	if fireproximityprompt then 
		local ok = pcall(function() fireproximityprompt(prompt) end) 
		if ok then return true end 
	end 
	local ok = pcall(function() 
		prompt:InputHoldBegin() 
		task.wait((prompt.HoldDuration or 0) + INTERACT_DELAY) 
		prompt:InputHoldEnd() 
	end) 
	return ok 
end

local function collectItem(item) 
	if not item then return end 
	local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true) 
	local pos = getItemPosition(item) 
	
	if pos then 
		teleportTo(pos) 
		task.wait(0.15) 
		if prompt then 
			local ok = firePrompt(prompt) 
			dbg("Fired prompt on:", item.Name, "Success status:", ok) 
		else 
			dbg("No ProximityPrompt found inside object tree:", item.Name) 
		end 
	else 
		dbg("Could not translate vectors for object instance:", item.Name) 
	end 
end

-- ====== CONTINUOUS AUTO-FARM ENGINE LOOP ======
local function startFarmingLoop() 
	dbg("Automation runtime initiated.") 
	while isFarming do 
		local foundAnyItem = false 
		local char = player.Character 
		
		if char and char:FindFirstChild("HumanoidRootPart") then 
			local allObjects = ITEMS_PARENT:GetDescendants() 
			
			for _, object in ipairs(allObjects) do 
				if not isFarming then break end 
				
				-- Match names directly
				if targetItems[object.Name] then 
					foundAnyItem = true 
					
					-- 1. Teleport to item and take it
					collectItem(object) 
					task.wait(0.15) 
					
					-- 2. Immediately teleport to drop positions to secure it
					if isFarming then
						teleportTo(TELEPORT_DROP_ZONE)
						task.wait(0.2) -- Brief pause at drop coordinates
					end
				end 
			end 
		else 
			dbg("Waiting for humanoid physics root parameters...") 
			task.wait(1) 
		end 
		
		-- Loop reset constraint: fast refresh if objects are ready, slight back-off if map is empty
		task.wait(foundAnyItem and 0.5 or 2.0) 
	end 
	dbg("Automation runtime terminated.") 
end

-- ====== CORE UI BUTTON HOOK CONNECTIONS ====== 

-- Connect Close Button Viewport Collapse
closeButton.MouseButton1Click:Connect(function()
	mainGui.Visible = false
end)

-- Hotkey Keybind 'K' To Unhide Main Windows
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end 
	if input.KeyCode == Enum.KeyCode.K then
		mainGui.Visible = not mainGui.Visible
	end
end)

-- Connect Inner Panel Slide Toggle Window
drillToggleBtn.MouseButton1Click:Connect(function() 
	drillSubPanel.Visible = not drillSubPanel.Visible 
end)

-- Connect Runtime Loop Automation Toggle
autoFarmBtn.MouseButton1Click:Connect(function() 
	isFarming = not isFarming 
	if isFarming then 
		autoFarmBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0) 
		autoFarmBtn.Text = "Auto Farm: ON" 
		task.spawn(startFarmingLoop) 
	else 
		autoFarmBtn.BackgroundColor3 = Color3.fromRGB(53, 53, 53) 
		autoFarmBtn.Text = "Auto Farm" 
	end 
end)

dbg("AWESOME HUB loaded successfully. Press 'K' to open/close.")
