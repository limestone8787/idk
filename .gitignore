-- ====== REBUILT LOGIC ENGINES ====== 
local function teleportTo(position) 
	local char = player.Character if not char then return end 
	local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end 
	hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0)) 
	task.wait(0.12) 
end

local function getItemPosition(item) 
	if not item then return nil end 
	if item:IsA("BasePart") then return item.Position end 
	if item:IsA("Model") then 
		if item.PrimaryPart then return item.PrimaryPart.Position end 
		local part = item:FindFirstChildWhichIsA("BasePart", true) 
		if part then return part.Position end 
	end 
	local deepPart = item:FindFirstChildWhichIsA("BasePart", true) 
	return deepPart and deepPart.Position or nil 
end

local function firePrompt(prompt) 
	if not prompt then return end 
    -- Use executor function if available
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        pcall(function() 
            prompt:InputHoldBegin() 
            task.wait((prompt.HoldDuration or 0) + INTERACT_DELAY) 
            prompt:InputHoldEnd() 
        end) 
    end
end

local function startFarmingLoop() 
	print("[AutoFarm] Activated loop.") 
	while isFarming do 
		local foundItems = false 
		local char = player.Character 
		
		if char and char:FindFirstChild("HumanoidRootPart") then 
            -- Getting children since items are in Workspace
			local list = ITEMS_PARENT:GetChildren() 
			
			for _, object in ipairs(list) do 
				if not isFarming then break end 
				
				if targetItems[object.Name] then 
					local pos = getItemPosition(object) 
					local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true) 
					
					if pos and prompt then 
						foundItems = true 
						teleportTo(pos) 
						task.wait(0.15) 
						firePrompt(prompt) 
						task.wait(0.15) 
						
						if isFarming then 
							teleportTo(TELEPORT_DROP_ZONE) 
							task.wait(0.2) 
						end 
					end 
				end 
			end 
		end 
		task.wait(foundItems and 0.5 or 2.0) 
	end 
	print("[AutoFarm] Deactivated loop.") 
end

-- ====== STABLE SIGNALS HOOK UP ====== 
closeButton.MouseButton1Click:Connect(function() 
	mainGui.Visible = false 
end)

UserInputService.InputBegan:Connect(function(input, processed) 
	if processed then return end 
	if input.KeyCode == Enum.KeyCode.K then 
		mainGui.Visible = not mainGui.Visible 
	end 
end)

drillToggleBtn.MouseButton1Click:Connect(function() 
	drillSubPanel.Visible = not drillSubPanel.Visible 
end)

autoFarmBtn.MouseButton1Click:Connect(function() 
	isFarming = not isFarming 
	if isFarming then 
		autoFarmBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0) 
		autoFarmBtn.Text = "Auto Farm: ON" 
		task.spawn(startFarmingLoop) 
	else 
		autoFarmBtn.BackgroundColor3 = Color3.fromRGB(53, 53, 53) 
		autoFarmBtn.Text = "Auto Farm" 
	end 
end)

print("[AWESOME HUB] Loaded - Items parented to Workspace. Press 'K' to hide/show.")
