strokeAuto.Thickness = 3 
strokeAuto.Color = Color3.fromRGB(31, 31, 31)


-- ====== ANTI-CHEAT BYPASS SYSTEM LOGIC ====== 

local function teleportTo(position) 
    local char = player.Character if not char then return end 
    local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end 
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if hum then 
        hum.Sit = true 
    end
    task.wait(0.01)
    
    hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0)) 
    
    hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
    hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)
    task.wait(0.15)
    
    if hum then hum.Sit = false end 
end

local function firePrompt(prompt) 
    if not prompt then return end 
    if fireproximityprompt then 
        pcall(function() fireproximityprompt(prompt) end)
    else 
        pcall(function() 
            prompt:InputHoldBegin() 
            task.wait((prompt.HoldDuration or 0) + INTERACT_DELAY) 
            prompt:InputHoldEnd() 
        end) 
    end 
end

local function getRealItemsFolder()
    for _, child in ipairs(Workspace:GetChildren()) do
        if child.Name == "Items" and child:IsA("Folder") then
            for _, descendant in ipairs(child:GetDescendants()) do
                if targetItems[descendant.Name] then
                    return child 
                end
            end
        end
    end
    return nil
end

local function startFarmingLoop() 
    while isFarming do 
        local foundItems = false 
        local realItemsFolder = getRealItemsFolder()
        
        if realItemsFolder and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
            local allElements = realItemsFolder:GetDescendants()
            
            for _, object in ipairs(allElements) do 
                if not isFarming then break end 
                
                if targetItems[object.Name] then 
                    local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true) 
                    local part = object:IsA("BasePart") and object or object:FindFirstChildWhichIsA("BasePart", true)
                    
                    if part and prompt then 
                        foundItems = true 
                        
                        teleportTo(part.Position) 
                        task.wait(0.12) 
                        
                        firePrompt(prompt) 
                        task.wait(0.12) 
                        
                        if isFarming then 
                            teleportTo(TELEPORT_DROP_ZONE) 
                            task.wait(0.2) 
                        end 
                    end 
                end 
            end 
        end 
        task.wait(foundItems and 0.3 or 1.5) 
    end 
end

-- ====== SIGNALS INTERFACE ATTACHMENTS ====== 
drillToggleBtn.MouseButton1Click:Connect(function() 
    drillSubPanel.Visible = not drillSubPanel.Visible 
end)

autoFarmBtn.MouseButton1Click:Connect(function() 
    isFarming = not isFarming 
    autoFarmBtn.BackgroundColor3 = isFarming and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(53, 53, 53)
    autoFarmBtn.Text = isFarming and "Auto Farm: ON" or "Auto Farm"
    if isFarming then task.spawn(startFarmingLoop) end
end)

-- GLOBAL KEYBIND TOGGLE (Using 'P' Key)
UserInputService.InputBegan:Connect(function(input, processed) 
    if not processed and input.KeyCode == Enum.KeyCode.P then 
        mainGui.Visible = not mainGui.Visible 
    end 
end)
